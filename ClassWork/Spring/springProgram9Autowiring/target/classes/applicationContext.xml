<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
    <bean class="com.spring.beans.Address" id="address1" autowire-candidate="false"> 
    <constructor-arg  value="111 " />
    <constructor-arg  value=" delhi" />
    <constructor-arg  value=" 201310" />
    </bean>
    
     <bean class="com.spring.beans.Address" id="address2" autowire-candidate="true"> 
    <constructor-arg  value="112" />
    <constructor-arg  value="chandigarh" />
    <constructor-arg  value=" 201311" />
    </bean>
    
     <bean class="com.spring.beans.Student" id="std1" autowire="constructor"> 
    <constructor-arg  value="aakanshi " index="0" />
    <constructor-arg  value=" 1" index="1" />
   
    </bean>


</beans>