class InsufficientFundsException extends Exception {
    public InsufficientFundsException(String message) {
        super(message);
    }
}

class AmountLessOrEqualToZeroException extends Exception {
    public AmountLessOrEqualToZeroException(String message) {
        super(message);
    }
}

class AmountExceedsLimitException extends Exception {
    public AmountExceedsLimitException(String message) {
        super(message);
    }
}

class AccountInactiveException extends Exception {
    public AccountInactiveException(String message) {
        super(message);
    }
}


class BankManager {
    private double balance = 10000.0;
    private boolean isAccountActive = true;

    // Method to validate withdrawal amount
    public void validateWithdrawal(double amount) throws AmountLessOrEqualToZeroException, AmountExceedsLimitException {
        if (amount <= 0) {
            throw new AmountLessOrEqualToZeroException("Withdrawal amount must be greater than zero.");
        }
        if (amount > 750000) {
            throw new AmountExceedsLimitException("Withdrawal amount exceeds the daily limit of 750,000.");
        }
    }

    public void withdraw(double amount) throws AmountLessOrEqualToZeroException, AmountExceedsLimitException, InsufficientFundsException, AccountInactiveException {
        validateWithdrawal(amount); // Propagate exceptions from here

        if (!isAccountActive) {
            throw new AccountInactiveException("Account is inactive.");
        }

        if (balance < amount) {
            throw new InsufficientFundsException("Insufficient funds. Current balance: " + balance);
        }

        balance -= amount;
        System.out.println("Successfully withdrew " + amount + ". New balance: " + balance);
    }
}


public class Main {
    public static void main(String[] args) {
        BankManager manager = new BankManager();
        double withdrawalAmount = 800000.0; 

        try {
            manager.withdraw(withdrawalAmount);
        } catch (AmountLessOrEqualToZeroException | AmountExceedsLimitException | InsufficientFundsException | AccountInactiveException e) {
            System.err.println("Transaction failed: " + e.getMessage());
        } finally {
            System.out.println("Transaction attempt completed.");
        }
    }
}
